---
layout: base.njk
---

<article style="max-width: 800px; margin: 0 auto; padding: 150px 20px 100px;">
    
    <div style="text-align: center; margin-bottom: 50px;">
        <span style="color: #666; font-size: 0.95rem;">{{ page.date | formatoFecha }}</span>
        <h1 style="font-size: 3rem; color: var(--color-principal); margin: 15px 0;">{{ title }}</h1>
        {% if description %}
        <p style="font-size: 1.25rem; color: #555; font-style: italic; max-width: 600px; margin: 0 auto;">{{ description }}</p>
        {% endif %}
    </div>

    {% if image %}
    <div class="articulo-img-container" style="margin-bottom: 50px; text-align: center;">
        {% optimizedImage image, title, "(max-width: 800px) 100vw, 1200px", "articulo-imagen-principal" %}
    </div>
    {% endif %}

    <div class="contenido-articulo" style="font-size: 1.15rem; color: #444; line-height: 1.8;">
        {{ content | safe }}
    </div>
    
    <hr style="border: none; border-top: 1px solid rgba(0,0,0,0.1); margin: 60px 0;">
    
    <div style="display: flex; align-items: center; justify-content: center; gap: 30px; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.03);">
        <img src="/fotoperfil.webp" alt="Fernando Bisceglia" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover;">
        <div>
            <h3 style="font-size: 1.3rem; margin-bottom: 10px; color: var(--color-texto);">Lic. Prof. Fernando Bisceglia</h3>
            <p style="font-size: 0.9rem; color: #666; margin-bottom: 15px;">Psicólogo Clínico. Especialista en Terapias Contextuales.</p>
            <a href="/#contacto" class="btn" style="padding: 8px 20px; font-size: 0.9rem;">Agendar un turno</a>
        </div>
    </div>
    
</article>

<style>
    /* Estilos específicos para el markdown generado */
    .contenido-articulo h2 {
        font-size: 2rem;
        color: var(--color-principal);
        margin: 40px 0 20px;
    }
    .contenido-articulo h3 {
        font-size: 1.5rem;
        margin: 30px 0 15px;
    }
    .contenido-articulo p {
        margin-bottom: 25px;
    }
    .contenido-articulo ul, .contenido-articulo ol {
        margin: 0 0 25px 20px;
    }
    .contenido-articulo li {
        margin-bottom: 10px;
    }
    .contenido-articulo strong {
        color: var(--color-texto);
    }
    .contenido-articulo blockquote {
        border-left: 4px solid var(--color-principal);
        padding-left: 20px;
        margin: 30px 0;
        font-style: italic;
        color: #555;
    }
    .articulo-img-container {
        width: 100%;
        max-width: 100%;
        overflow: visible; /* To allow shadow */
    }
    
    .articulo-img-container picture {
        display: block;
        width: 100%;
        max-width: 700px;
        margin: 0 auto;
    }
    
    .articulo-imagen-principal {
        display: block;
        width: 100%;
        height: auto;
        max-height: 500px;
        object-fit: cover;
        margin: 0 auto;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
</style>
